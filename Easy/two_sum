# nums = [2,7,11,15]
# target = 9

# Output: [0,1]

def two_sum(nums: list, target: int) -> list:

    sumMap = {}

    for i, item in enumerate(nums):
        extra = target - item
        if extra in sumMap:
            return [sumMap[extra], i]
    
        sumMap[item] = i 

    return    



nums = [-1,-2,-3,-4]
target = -6

result = two_sum(nums, target)
print("Result : ", result)    