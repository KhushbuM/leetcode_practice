# Output:
# [24,12,8,6]

def product_except_self(nums: list) -> list:
    prefix_list = []
    postfix_list = []
    result = []
    prefix = 1
    postfix = 1

    for i in nums:
        prefix_list.append(prefix)
        prefix = prefix * i

    for j in reversed(nums):
        postfix_list.append(postfix) 
        postfix = postfix * j

    postfix_list.reverse()

    for i in range(len(nums)):
        result.append(prefix_list[i] * postfix_list[i])

    return result    



nums = [1, 2, 3, 4]
print(product_except_self(nums))